// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Core data model for the Airtable-style app.
/// Focused on bases, tables, columns, rows, cells, and views.

// --- Auth / users (NextAuth-compatible) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  bases            Base[]   @relation("BaseOwner")
  createdBases     Base[]   @relation("BaseCreatedBy")
  createdTables    Table[]  @relation("TableCreatedBy")
  createdColumns   Column[] @relation("ColumnCreatedBy")
  createdRows      Row[]    @relation("RowCreatedBy")
  createdViews     View[]   @relation("ViewCreatedBy")
  createdViewFilters      ViewFilter[]           @relation("ViewFilterCreatedBy")
  createdViewSorts        ViewSort[]             @relation("ViewSortCreatedBy")
  createdViewColumnVis    ViewColumnVisibility[] @relation("ViewColumnVisibilityCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @map("refresh_token")
  access_token      String? @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token")
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Airtable-style data model ---

/// A "base" groups tables together, like an Airtable base or workbook.
model Base {
  id        String   @id @default(cuid())
  name      String

  ownerId     String
  owner       User     @relation("BaseOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?    @relation("BaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  tables    Table[]

  /// Position of this base in the user's base list.
  position  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, position])
  @@index([createdById])
}

/// A table within a base (e.g. "Tasks", "Contacts").
model Table {
  id        String   @id @default(cuid())
  baseId      String
  base        Base     @relation(fields: [baseId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?    @relation("TableCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  name      String
  position  Int      @default(0)

  rows      Row[]
  columns   Column[]
  views     View[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([baseId, position])
  @@index([createdById])
}

/// Supported column types for now.
enum ColumnType {
  TEXT
  NUMBER
}

/// A column definition for a table (name, type, and order).
model Column {
  id        String   @id @default(cuid())
  tableId     String
  table       Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?    @relation("ColumnCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  name      String
  type      ColumnType
  position  Int      @default(0)

  cells     Cell[]
  viewVis   ViewColumnVisibility[]
  viewFilters ViewFilter[]
  viewSorts   ViewSort[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tableId, position])
  @@index([createdById])
}

/// A logical row in a table. Individual values live in the Cell model.
model Row {
  id         String   @id @default(cuid())
  tableId     String
  table       Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?    @relation("RowCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  /// Stable row index used for ordering.
  index      Int

  /// Denormalized text used to accelerate search across the row.
  searchText String   @default("")

  cells      Cell[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tableId, index])
  @@index([tableId, searchText])
  @@index([createdById])
}

/// A single cell value for a (row, column) pair.
model Cell {
  id          String    @id @default(cuid())

  rowId       String
  row         Row       @relation(fields: [rowId], references: [id], onDelete: Cascade)

  columnId    String
  column      Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)

  textValue   String?
  numberValue Float?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([rowId, columnId])
  @@index([columnId])
}

/// A saved view on a table (filters, sort, search, column visibility).
model View {
  id               String                 @id @default(cuid())
  tableId          String
  table            Table                  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  createdById      String?
  createdBy        User?                  @relation("ViewCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  name             String
  searchQuery      String?

  /// How filter conditions combine: "AND" (match all) or "OR" (match any). Default AND.
  filterLogicalOperator String?

  /// Position of this view in the table's view list.
  position         Int                    @default(0)

  filters          ViewFilter[]
  sorts            ViewSort[]
  columnVisibility ViewColumnVisibility[]

  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([tableId, name])
  @@index([tableId, position])
  @@index([createdById])
}

/// Filter operators supported in views.
enum FilterOperator {
  IS_EMPTY
  IS_NOT_EMPTY
  CONTAINS
  NOT_CONTAINS
  EQUALS
  GREATER_THAN
  LESS_THAN
}

/// A single filter condition within a view.
model ViewFilter {
  id        String          @id @default(cuid())

  viewId      String
  view        View            @relation(fields: [viewId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?           @relation("ViewFilterCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  columnId  String
  column    Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)

  operator  FilterOperator

  /// Raw string representation of the value; interpreted as text or number in the app.
  value     String?

  /// Position of this filter within the view's filter list.
  position  Int             @default(0)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([viewId])
  @@index([viewId, position])
  @@index([columnId])
  @@index([createdById])
}

/// Sort direction for a view.
enum SortDirection {
  ASC
  DESC
}

/// A single sort configuration within a view (single-column sort for now).
model ViewSort {
  id        String        @id @default(cuid())

  viewId      String
  view        View          @relation(fields: [viewId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?         @relation("ViewSortCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  columnId  String
  column    Column        @relation(fields: [columnId], references: [id], onDelete: Cascade)

  direction SortDirection
  priority  Int           @default(0)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([viewId])
  @@index([viewId, priority])
  @@index([columnId])
  @@index([createdById])
}

/// Per-view visibility of a column (hide/show).
model ViewColumnVisibility {
  id        String   @id @default(cuid())

  viewId      String
  view        View     @relation(fields: [viewId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?    @relation("ViewColumnVisibilityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  columnId  String
  column    Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)

  visible   Boolean  @default(true)
  position  Int?     // optional per-view ordering, if needed later

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([viewId, columnId])
  @@index([viewId])
  @@index([columnId])
  @@index([createdById])
}
